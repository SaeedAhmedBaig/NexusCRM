# ── Shared ──────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (copy to frontend/.env.local) ────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost
# Server-side API proxy target for Vercel. Use the Render backend root URL, without /api.
# Example: https://your-crm-backend.onrender.com
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Render cold starts can take longer than normal API calls.
API_PROXY_TIMEOUT_MS=55000

# ── Backend (copy to backend/.env) ──────────────────────
PORT=4000
APP_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/crm_saas
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
DEFAULT_TRIAL_DAYS=14
REQUEST_BODY_LIMIT=12mb
# Platform superadmin — auto-provisioned on backend startup (no signup)
SUPERADMIN_EMAIL=admin@nexuscrm.com
SUPERADMIN_PASSWORD=NexusAdmin@2026
SUPERADMIN_TENANT_SUBDOMAIN=system
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
ENCRYPTION_KEY=

# ── reCAPTCHA v3 (optional) ───────────────────────────
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Brevo (transactional email via REST API) ───────────
# API key from Brevo → Settings → SMTP & API → API Keys
# Sender email must be verified under Senders & Domains
# Note: SMTP port (587/465) is only for SMTP relay — this app uses the HTTP API
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=NexusCRM
CONTACT_SALES_EMAIL=

# ── Frontend WebSocket (optional — defaults to API URL) ─
NEXT_PUBLIC_WS_URL=

# ── Google OAuth / Gmail ───────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ── Demo CRM seed (optional) ───────────────────────────
SEED_DEMO_DATA=false

# ── Stripe (billing – test mode) ────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_BUSINESS=price_business_monthly
STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly

# ── Zadarma VoIP (optional – falls back to tel: dialer) ─
ZADARMA_KEY=
ZADARMA_SECRET=
ZADARMA_FROM_NUMBER=

# ── Redis / BullMQ (later phases – not required in Phase 1) ──
REDIS_URL=redis://127.0.0.1:6379
